# Flint local development — copy to `.env` and export before `npm run tauri dev`.
# Never commit `.env` (see .gitignore).

# Supabase (required for auth, session sync, feature-flag refresh)
# Run `supabase start` then `supabase status` for local URL + anon key.
FLINT_SUPABASE_URL=http://127.0.0.1:54321
FLINT_SUPABASE_ANON_KEY=

# Smart Resume handoff (Strategy B Phase 1) — FastAPI base URL, no trailing slash.
FLINT_SMART_RESUME_URL=http://localhost:8000

# Optional: override OAuth redirect (default in dev builds: Vite bridge page)
# FLINT_OAUTH_REDIRECT_URI=http://127.0.0.1:1420/oauth-callback.html
# FLINT_LOG=info,flint=debug

# Tavily web search (rehearsal prep-mode research) — optional; can also set in Settings → API Keys.
# TAVILY_API_KEY=tvly-…
