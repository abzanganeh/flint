# Flint local development — copy to `.env` and export before `npm run tauri dev`.
# Never commit `.env` (see .gitignore).

# Supabase (required for auth, session sync, feature-flag refresh)
# Run `supabase start` then `supabase status` for local URL + anon key.
FLINT_SUPABASE_URL=http://127.0.0.1:54321
FLINT_SUPABASE_ANON_KEY=

# Optional: override default tracing (release: info; debug builds: info,flint=debug)
# FLINT_LOG=info,flint=debug
